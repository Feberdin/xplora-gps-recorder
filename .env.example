# Purpose: Example configuration for local development and Docker deployments.
# Inputs: Values are loaded by Pydantic settings from `.env`.
# Outputs: Runtime configuration for the API, scheduler, database, and integrations.
# Invariants: Secrets stay outside version control; update `POSTGRES_URL` when database values change.
# Debugging: Start with `LOG_LEVEL=DEBUG` and verify the Xplora login mode, country code, and GraphQL endpoint first.

APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=true
LOG_INCLUDE_SQL=false

API_HOST=0.0.0.0
API_PORT=8000
POLL_INTERVAL_SECONDS=60
DEFAULT_QUERY_LIMIT=500

# Choose one database mode:
# 1. Embedded SQLite for simple installs:
SQLITE_PATH=./data/xplora_gps_recorder.db
# 2. Or a full external database URL:
DATABASE_URL=postgresql+psycopg://xplora:change-me@postgres:5432/xplora_gps

POSTGRES_DB=xplora_gps
POSTGRES_USER=xplora
POSTGRES_PASSWORD=change-me

REDIS_URL=

XPLORA_BASE_URL=https://api.myxplora.com/api
XPLORA_COUNTRY_CODE=
XPLORA_USER_LANG=en-GB
XPLORA_TIME_ZONE=UTC
XPLORA_TRIGGER_LOCATE=true
# Legacy REST placeholders, ignored by the current GraphQL mode:
XPLORA_LOGIN_PATH=/auth/login
XPLORA_DEVICES_PATH=/v1/devices
XPLORA_LOCATION_PATH=
XPLORA_USERNAME=replace-me@example.com
XPLORA_PASSWORD=replace-me
XPLORA_VERIFY_SSL=true
XPLORA_TIMEOUT_SECONDS=15
XPLORA_MAX_RETRIES=3

REVERSE_GEOCODE_ENABLED=true
REVERSE_GEOCODE_URL=https://nominatim.openstreetmap.org/reverse
REVERSE_GEOCODE_USER_AGENT=xplora-gps-recorder/1.0 (+https://github.com/Feberdin/xplora-gps-recorder)
REVERSE_GEOCODE_CACHE_PRECISION=4
REVERSE_GEOCODE_MIN_INTERVAL_SECONDS=1.0

STATIONARY_DISTANCE_METERS=20
STATIONARY_WINDOW_SECONDS=300
HEATMAP_TILE_PRECISION=3

MQTT_ENABLED=false
MQTT_HOST=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=kids/watch
MQTT_TLS_ENABLED=false
